# Copy to .env on the server (same folder as docker-compose.yml)

# Required
JWT_SECRET=change-me-long-random

# Optional (defaults inside compose)
MONGO_URI=mongodb://mongo:27017/smart_healthcare

# Set to your real domain in production (used for backend CORS allowlist)
FRONTEND_ORIGIN=http://your-domain.com

# Abi (Option 1)
ABI_API_BASE_URL=https://client-api.abi.ai
ABI_API_KEY=
ABI_DEFAULT_LANGUAGE=en
ABI_DEFAULT_PHYSICIAN_COUNTRY=ie
ABI_PARTNER_NAME=goodpeople
ABI_WIDGET_BASE_URL=http://goapp.abi.ai
ABI_WIDGET_PARTNER=goodpeople

# Optional
ABI_WEBHOOK_SECRET=

# Dev-only; keep false in prod
ABI_USE_TEST_IDENTITY=false
ABI_TEST_EMAIL=support@clienttask.com
ABI_TEST_NAME=Test Name

