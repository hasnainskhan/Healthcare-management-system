MONGO_URI=mongodb://127.0.0.1:27017/smart_healthcare
JWT_SECRET=
PORT=5000
FRONTEND01=http://localhost:5173

# Local DB: from repo root run  docker compose up -d
# Then  cd BACKEND && npm start

# ABI / GoApp integration (server only — never expose ABI_API_KEY to the browser)
# Base URL from Abi API Reference docs
ABI_API_BASE_URL=https://client-api.abi.ai
ABI_API_KEY=

# Partner-specific defaults (confirmed by client: en + ie, partnerName goodpeople)
ABI_DEFAULT_LANGUAGE=en
ABI_DEFAULT_PHYSICIAN_COUNTRY=ie
ABI_PARTNER_NAME=goodpeople

# Dev-only: force a non-personal test identity for ABI onboarding
ABI_USE_TEST_IDENTITY=false
ABI_TEST_EMAIL=support@clienttask.com
ABI_TEST_NAME=Test Name

# GoApp widget (client confirmed): http://goapp.abi.ai/goodpeople/{uniqueId}
ABI_WIDGET_BASE_URL=http://goapp.abi.ai
ABI_WIDGET_PARTNER=goodpeople

# Legacy / optional (not used by Abi POST /user in current integration)
ABI_CONSENT_VERSION=v1

# Optional: HMAC secret for POST /api/abi/webhook — must match ABI dashboard configuration
ABI_WEBHOOK_SECRET=
